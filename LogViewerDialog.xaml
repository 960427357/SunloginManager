<Window x:Class="SunloginManager.LogViewerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SunloginManager"
        mc:Ignorable="d"
        Title="日志查看器" 
        Height="200" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- 苹果风格按钮样式 -->
        <Style x:Key="AppleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0051D5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004BB5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="White" CornerRadius="12" Margin="20" Padding="20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.1" ShadowDepth="0" BlurRadius="15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="日志查看器" FontSize="20" FontWeight="SemiBold" 
                       Margin="0,0,0,20" Foreground="#1D1D1F" HorizontalAlignment="Center"/>
            
            <!-- 说明文本 -->
            <TextBlock Grid.Row="1" Text="点击下方按钮打开日志目录，您可以在文件资源管理器中查看所有日志文件。" 
                       FontSize="14" Foreground="#1D1D1F" TextWrapping="Wrap" 
                       VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20"/>
            
            <!-- 按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="打开日志目录" Style="{StaticResource AppleButtonStyle}" Width="150" Height="40" 
                        Click="ViewLogsButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>