<Window x:Class="SunloginManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SunloginManager"
        mc:Ignorable="d"
        Title="向日葵远程连接管理器" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7">
    
    <Window.Resources>
        <!-- 值转换器 -->
        <local:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <local:ConnectionCodeMaskConverter x:Key="ConnectionCodeMaskConverter"/>
        <local:BoolToStarConverter x:Key="BoolToStarConverter"/>
        
        <!-- 苹果风格按钮样式 -->
        <Style x:Key="AppleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0051D5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004BB5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 苹果风格卡片样式 -->
        <Style x:Key="AppleCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.1" ShadowDepth="0" BlurRadius="15"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 苹果风格文本框样式 -->
        <Style x:Key="AppleTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#D1D1D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="45"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Opacity" TargetName="border" Value="0.56"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 连接状态指示器样式 -->
        <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Fill" Value="#34C759"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Fill" Value="#8E8E93"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- 表格行样式 -->
        <Style x:Key="TableRowStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F2F2F7"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F2FF"/>
                                <Setter Property="BorderBrush" Value="#007AFF"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 表格操作按钮样式 -->
        <Style x:Key="TableButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#007AFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F8FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E6F2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 苹果风格下拉框样式 -->
        <Style x:Key="AppleComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#D1D1D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="0"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="#D1D1D6"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="12,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                                <Path Grid.Column="1"
                                                      x:Name="Arrow"
                                                      Margin="0,0,12,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Right"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#8E8E93"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#007AFF"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#007AFF"/>
                                                <Setter TargetName="Arrow" Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,0,30,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="White"
                                        BorderBrush="#D1D1D6"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="300"
                                        Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.15" ShadowDepth="2" BlurRadius="8"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="0,4"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.56"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox下拉项样式 -->
        <Style x:Key="AppleComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F8FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6F2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 苹果风格右键菜单样式 -->
        <Style x:Key="AppleContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                MinWidth="180">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.15" ShadowDepth="0" BlurRadius="20"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 苹果风格菜单项样式 -->
        <Style x:Key="AppleMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Icon}" FontSize="14" Width="22" Margin="0,0,8,0" TextAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Header}" FontSize="{TemplateBinding FontSize}"
                                           Foreground="{TemplateBinding Foreground}" FontWeight="{TemplateBinding FontWeight}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F0FE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D0E2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 删除菜单项样式（红色文字） -->
        <Style x:Key="AppleDeleteMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource AppleMenuItemStyle}">
            <Setter Property="Foreground" Value="#FF3B30"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF0EE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 苹果风格分隔线样式 -->
        <Style x:Key="AppleMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="#E5E5E5" Height="1" CornerRadius="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 右键菜单 -->
        <ContextMenu x:Key="ConnectionContextMenu" Style="{StaticResource AppleContextMenuStyle}">
            <MenuItem Header="收藏" Click="ContextToggleFavorite_Click" Style="{StaticResource AppleMenuItemStyle}" Icon="⭐"/>
            <MenuItem Header="连接" Click="ContextConnect_Click" Style="{StaticResource AppleMenuItemStyle}" Icon="🔗"/>
            <MenuItem Header="测试连接" Click="ContextTestConnect_Click" Style="{StaticResource AppleMenuItemStyle}" Icon="🧪"/>
            <MenuItem Header="编辑" Click="ContextEdit_Click" Style="{StaticResource AppleMenuItemStyle}" Icon="✏️"/>
            <MenuItem Header="分享" Click="ContextShare_Click" Style="{StaticResource AppleMenuItemStyle}" Icon="📤"/>
            <Separator Style="{StaticResource AppleMenuSeparatorStyle}"/>
            <MenuItem Header="删除" Click="ContextDelete_Click" Style="{StaticResource AppleDeleteMenuItemStyle}" Icon="🗑️"/>
        </ContextMenu>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="White" Height="60" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" ShadowDepth="1" BlurRadius="5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="向日葵远程连接管理器" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1D1D1F"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Button Content="刷新" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,5,0" Click="RefreshButton_Click"/>
                    <Button Content="历史" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,5,0" Click="HistoryButton_Click"/>
                    <Button Content="统计" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,5,0" Click="StatsButton_Click"/>
                    <Button Content="测试" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,5,0" Click="TestConnectionButton_Click"/>
                    <Button Content="分组" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,5,0" Click="ManageGroupsButton_Click"/>
                    <Button Content="设置" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,5,0" Click="SettingsButton_Click"/>
                    <Button Content="关于" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,0,0" Click="AboutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：连接列表 -->
            <Border Grid.Column="0" Style="{StaticResource AppleCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="远程连接列表" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#1D1D1F"/>
                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox x:Name="GroupFilterComboBox" 
                                  Width="150" 
                                  Height="45" 
                                  Margin="0,0,10,0"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectionChanged="GroupFilterComboBox_SelectionChanged"
                                  Style="{StaticResource AppleComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource AppleComboBoxItemStyle}"/>
                        <Grid Width="250" Height="45">
                            <TextBox x:Name="SearchTextBox" Style="{StaticResource AppleTextBoxStyle}" Width="250" Height="45" TextChanged="SearchTextBox_TextChanged"/>
                            <TextBlock x:Name="SearchPlaceholder" Text="搜索连接..." VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#8E8E93" IsHitTestVisible="False" Visibility="Collapsed"/>
                        </Grid>
                        <Button Content="添加连接" Style="{StaticResource AppleButtonStyle}" Width="120" Height="45" Margin="10,0,0,0" Click="AddConnectionButton_Click"/>
                    </StackPanel>
                    
                    <ListView x:Name="ConnectionsListView" Grid.Row="2" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemsSource="{Binding Connections}" ItemContainerStyle="{StaticResource TableRowStyle}" PreviewMouseDoubleClick="ConnectionsListView_MouseDoubleClick" PreviewMouseLeftButtonDown="ConnectionsListView_PreviewMouseLeftButtonDown" MouseRightButtonDown="ConnectionsListView_MouseRightButtonDown" ContextMenu="{StaticResource ConnectionContextMenu}">
                        <ListView.Resources>
                            <Style x:Key="SortableHeaderStyle" TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#F5F5F7"/>
                                <Setter Property="Foreground" Value="#1D1D1F"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderBrush" Value="#E5E5E5"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="SortArrow" Visibility="Collapsed" Margin="4,0,0,0" FontSize="10"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#EBEBEF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <!-- 收藏列 -->
                                <GridViewColumn Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- 状态列 -->
                                <GridViewColumn Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Style="{StaticResource StatusIndicatorStyle}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                
                                <!-- 名称列 -->
                                <GridViewColumn Width="150" DisplayMemberBinding="{Binding Name}">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="名称" Style="{StaticResource SortableHeaderStyle}" Tag="Name" Click="GridViewColumnHeader_Click"/>
                                    </GridViewColumn.Header>
                                </GridViewColumn>
                                
                                <!-- 识别码列 -->
                                <GridViewColumn Header="识别码" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IdentificationCode}" FontFamily="Consolas"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                
                                <!-- 连接码列 -->
                                <GridViewColumn Header="连接码" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ConnectionCode, Converter={StaticResource ConnectionCodeMaskConverter}}" FontFamily="Consolas"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                
                                <!-- 最后连接时间列 -->
                                <GridViewColumn Width="180">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="最后连接" Style="{StaticResource SortableHeaderStyle}" Tag="LastConnectedAt" Click="GridViewColumnHeader_Click"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LastConnectedAt, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                
                                <!-- 操作列 -->
                                <GridViewColumn Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource TableButtonStyle}"
                                                        ToolTip="连接"
                                                        Click="ConnectFromTableButton_Click">
                                                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"/>
                                                </Button>
                                                <Button Style="{StaticResource TableButtonStyle}"
                                                        ToolTip="分享"
                                                        Click="ShareFromTableButton_Click">
                                                    <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets"/>
                                                </Button>
                                                <Button Style="{StaticResource TableButtonStyle}"
                                                        ToolTip="编辑"
                                                        Click="EditFromTableButton_Click">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"/>
                                                </Button>
                                                <Button Style="{StaticResource TableButtonStyle}"
                                                        ToolTip="删除"
                                                        Click="DeleteFromTableButton_Click">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
            
            <!-- 右侧：连接详情和操作 -->
            <Border Grid.Column="1" Style="{StaticResource AppleCardStyle}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="连接详情" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#1D1D1F"/>
                    
                    <!-- 连接状态指示器 -->
                    <Border Grid.Row="1" Background="#F2F2F7" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Style="{StaticResource StatusIndicatorStyle}" Width="12" Height="12"/>
                                <TextBlock x:Name="ConnectionStatusText" 
                                           Text="{Binding SelectedConnection.IsEnabled, Converter={StaticResource BoolToStatusConverter}}"
                                           FontSize="14" 
                                           FontWeight="Medium" 
                                           Foreground="{Binding SelectedConnection.IsEnabled, Converter={StaticResource BoolToColorConverter}}"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="QuickConnectButton" Content="快速连接" Style="{StaticResource AppleButtonStyle}" Width="90" Height="35" Click="ConnectFromDetailsButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ConnectionDetailsPanel">
                            <TextBlock Text="请从左侧列表中选择一个连接" FontSize="14" Foreground="#8E8E93" HorizontalAlignment="Center" Margin="0,50"/>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button x:Name="ShareButton" Content="分享" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,10,0" Click="ShareButton_Click"/>
                        <Button Content="编辑" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Margin="0,0,10,0" Click="EditFromDetailsButton_Click"/>
                        <Button Content="删除" Style="{StaticResource AppleButtonStyle}" Width="70" Height="35" Background="#FF3B30" Click="DeleteFromDetailsButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        
        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="White" Height="50" Margin="0,10,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" ShadowDepth="-1" BlurRadius="5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" x:Name="StatusTextBlock" Text="" VerticalAlignment="Center" Margin="20,0" FontSize="14" Foreground="#8E8E93"/>
                <Button Grid.Column="1" Content="查看日志" Style="{StaticResource AppleButtonStyle}" Width="100" Height="35" Margin="0,0,10,0" Click="ViewLogsButton_Click"/>
            </Grid>
        </Border>

        <!-- 锁定覆盖层（隐藏状态） -->
        <Grid x:Name="LockOverlay" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="1000" Focusable="True">
            <Border Background="White" CornerRadius="12" Padding="30,25" Width="350"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.3" ShadowDepth="0" BlurRadius="20"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="LockTitleText" Text="屏幕已锁定" FontSize="20" FontWeight="SemiBold"
                               Foreground="#1D1D1F" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="输入密码解锁" FontSize="13" Foreground="#8E8E93"
                               HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <!-- 密码输入 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="LockPasswordBox" Grid.Column="0"
                                     FontSize="14" VerticalContentAlignment="Center"
                                     Background="White" BorderBrush="#D1D1D6"
                                     BorderThickness="1" Padding="10,0,35,0" Height="40"
                                     KeyDown="LockPasswordBox_KeyDown">
                            <PasswordBox.Template>
                                <ControlTemplate TargetType="PasswordBox">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                        <ScrollViewer x:Name="PART_ContentHost"
                                                      Focusable="false"
                                                      HorizontalScrollBarVisibility="Hidden"
                                                      VerticalScrollBarVisibility="Hidden"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="true">
                                            <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                                        </Trigger>
                                        <Trigger Property="IsFocused" Value="true">
                                            <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </PasswordBox.Template>
                        </PasswordBox>
                        <Button Grid.Column="1" Content="&#x1F441;" Width="24" Height="24"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Click="LockEyeButton_Click"/>
                    </Grid>
                    <TextBox x:Name="LockPasswordTextBox"
                             Visibility="Collapsed" FontSize="14" Height="40"
                             VerticalContentAlignment="Center" Padding="10,0,35,0"
                             Margin="0,0,0,10" KeyDown="LockPasswordBox_KeyDown"
                             Background="White" BorderBrush="#D1D1D6" BorderThickness="1"
                             Style="{StaticResource AppleTextBoxStyle}"/>

                    <TextBlock x:Name="LockErrorText" Text="" FontSize="12" Foreground="#FF3B30"
                               HorizontalAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="退出" Height="36" Margin="0,0,5,0"
                                Background="#FF3B30" Foreground="White" FontWeight="Medium"
                                BorderThickness="0" Cursor="Hand"
                                Click="LockExitButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="1" Content="解锁" Height="36" Margin="5,0,0,0"
                                Background="#007AFF" Foreground="White" FontWeight="Medium"
                                BorderThickness="0" Cursor="Hand"
                                Click="LockUnlockButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>