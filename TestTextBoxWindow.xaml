<Window x:Class="SunloginManager.TestTextBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文本框测试" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="文本框测试" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="基本文本框:" Margin="0,0,0,5"/>
            <TextBox Text="这是一个基本的文本框" Margin="0,0,0,15"/>
            
            <TextBlock Text="黑色前景色文本框:" Margin="0,0,0,5"/>
            <TextBox Text="这是黑色前景色的文本框" Foreground="Black" Background="White" Margin="0,0,0,15"/>
            
            <TextBlock Text="红色前景色文本框:" Margin="0,0,0,5"/>
            <TextBox Text="这是红色前景色的文本框" Foreground="Red" Background="White" Margin="0,0,0,15"/>
        </StackPanel>
    </Grid>
</Window>