<Window x:Class="SunloginManager.BulkManageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SunloginManager"
        mc:Ignorable="d"
        Title="批量管理" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F7">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="批量管理" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <!-- 导入区域 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="导入连接" Margin="5,5,5,5" FontWeight="Medium"/>
            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                <TextBox x:Name="FilePathTextBox" Grid.Column="0" Height="35" Width="500" Text="选择文件或输入 CSV 内容..."/>
                <Button x:Name="BrowseButton" Content="浏览..." Width="100" Height="35" Click="BrowseButton_Click" Margin="5,0,5,0"/>
                <Button x:Name="ImportButton" Content="导入" Width="100" Height="35" Click="ImportButton_Click" Margin="5,0,5,0"/>
                <Button x:Name="ClearButton" Content="清空" Width="100" Height="35" Click="ClearButton_Click" Margin="5,0,5,0"/>
            </StackPanel>
        </StackPanel>

        <!-- 分组过滤区域 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="分组过滤" Margin="5,5,5,5" FontWeight="Medium"/>
            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                <ComboBox x:Name="GroupFilterComboBox"
                          Width="200"
                          Height="35"
                          Margin="0,0,10,0"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="GroupFilterComboBox_SelectionChanged"/>
                <Button x:Name="ApplyFilterButton" Content="应用过滤" Width="100" Height="35" Click="ApplyFilterButton_Click" Margin="5,0,5,0"/>
                <Button x:Name="ClearFilterButton" Content="清除过滤" Width="120" Height="35" Click="ClearFilterButton_Click" Margin="5,0,5,0"/>
                <Button x:Name="EditSelectedButton" Content="编辑" Width="80" Height="35" Click="EditSelectedButton_Click" Margin="5,0,5,0" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>

        <!-- 数据表格 -->
        <ListView Grid.Row="3"
                  x:Name="DataGrid"
                  IsSynchronizedWithCurrentItem="False"
                  BorderThickness="1"
                  BorderBrush="#D1D1D6"
                  Background="White"
                  SelectionMode="Single"
                  SelectionChanged="DataGrid_SelectionChanged"
                  Loaded="DataGrid_Loaded">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="名称" Width="150" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="识别码" Width="120" DisplayMemberBinding="{Binding IdentificationCode}"/>
                    <GridViewColumn Header="连接码" Width="120" DisplayMemberBinding="{Binding ConnectionCode}"/>
                    <GridViewColumn Header="备注" Width="150" DisplayMemberBinding="{Binding Remarks}"/>
                    <GridViewColumn Header="分组" Width="100" DisplayMemberBinding="{Binding GroupName}"/>
                    <GridViewColumn Header="状态" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsEnabled, Converter={StaticResource BoolToStatusConverter}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 统计信息 -->
        <TextBlock Grid.Row="4"
                   x:Name="StatusText"
                   Text="共 0 个连接"
                   Foreground="#666"
                   Margin="0,10,0,10"
                   VerticalAlignment="Center"/>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="取消" Width="100" Height="35" Click="CancelButton_Click" Margin="5,0,5,0"/>
            <Button x:Name="ConfirmButton" Content="确认导入" Width="120" Height="35" Click="ConfirmButton_Click" Margin="5,0,5,0"/>
        </StackPanel>
    </Grid>
</Window>
