<Window x:Class="SunloginManager.ConnectionStatsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="连接统计" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="连接统计" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="StatsPanel" Margin="0,0,0,10"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" Width="100" Height="35" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
