<Window x:Class="SunloginManager.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SunloginManager"
        mc:Ignorable="d"
        Title="输入主密码" Height="280" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F7">

    <Window.Resources>
        <Style x:Key="AppleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#007AFF"/>
            <Setter Property="BorderBrush" Value="#007AFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#007AFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0056CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3B30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3B30"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D63028"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock x:Name="TitleText" Grid.Row="0" Text="输入主密码" FontSize="20" FontWeight="SemiBold"
                   Foreground="#1A1A1A" Margin="0,0,0,5"/>
        <TextBlock x:Name="SubtitleText" Grid.Row="1" Text="" FontSize="12" Foreground="#8E8E93"
                   Margin="0,0,0,15"/>

        <!-- 当前密码 -->
        <StackPanel x:Name="CurrentPasswordRow" Grid.Row="2" Margin="0,0,0,10">
            <TextBlock x:Name="CurrentPasswordLabel" Text="当前密码" FontSize="13" FontWeight="Medium"
                       Foreground="#3A3A3C" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="CurrentPasswordBox" Grid.Column="0"
                             FontSize="14" VerticalContentAlignment="Center"
                             Background="White" BorderBrush="#D1D1D6"
                             BorderThickness="1" Padding="10,0,35,0" Height="40">
                    <PasswordBox.Template>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="false"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="true">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </PasswordBox.Template>
                </PasswordBox>
                <Button x:Name="CurrentEyeButton" Grid.Column="1" Content="👁" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Click="CurrentEyeButton_Click"/>
            </Grid>
            <TextBox x:Name="CurrentPasswordTextBox" Grid.Row="2"
                     Visibility="Collapsed" FontSize="14" Height="40"
                     VerticalContentAlignment="Center" Padding="10,0,35,0"
                     Background="White" BorderBrush="#D1D1D6" BorderThickness="1"/>
        </StackPanel>

        <!-- 新密码 -->
        <StackPanel x:Name="NewPasswordRow" Grid.Row="3" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock x:Name="NewPasswordLabel" Text="新密码" FontSize="13" FontWeight="Medium"
                       Foreground="#3A3A3C" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="NewPasswordBox" Grid.Column="0"
                             FontSize="14" VerticalContentAlignment="Center"
                             Background="White" BorderBrush="#D1D1D6"
                             BorderThickness="1" Padding="10,0,35,0" Height="40">
                    <PasswordBox.Template>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="false"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="true">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </PasswordBox.Template>
                </PasswordBox>
                <Button x:Name="NewEyeButton" Grid.Column="1" Content="👁" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Click="NewEyeButton_Click"/>
            </Grid>
            <TextBox x:Name="NewPasswordTextBox" Grid.Row="3"
                     Visibility="Collapsed" FontSize="14" Height="40"
                     VerticalContentAlignment="Center" Padding="10,0,35,0"
                     Background="White" BorderBrush="#D1D1D6" BorderThickness="1"/>
        </StackPanel>

        <!-- 确认新密码 -->
        <StackPanel x:Name="ConfirmNewPasswordRow" Grid.Row="4" Margin="0,0,0,5" Visibility="Collapsed">
            <TextBlock x:Name="ConfirmNewPasswordLabel" Text="确认新密码" FontSize="13" FontWeight="Medium"
                       Foreground="#3A3A3C" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="ConfirmNewPasswordBox" Grid.Column="0"
                             FontSize="14" VerticalContentAlignment="Center"
                             Background="White" BorderBrush="#D1D1D6"
                             BorderThickness="1" Padding="10,0,35,0" Height="40">
                    <PasswordBox.Template>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="false"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="true">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#007AFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </PasswordBox.Template>
                </PasswordBox>
                <Button x:Name="ConfirmEyeButton" Grid.Column="1" Content="👁" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Click="ConfirmEyeButton_Click"/>
            </Grid>
            <TextBox x:Name="ConfirmNewPasswordTextBox" Grid.Row="4"
                     Visibility="Collapsed" FontSize="14" Height="40"
                     VerticalContentAlignment="Center" Padding="10,0,35,0"
                     Background="White" BorderBrush="#D1D1D6" BorderThickness="1"/>
        </StackPanel>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" Style="{StaticResource AppleButtonStyle}"
                    Width="90" Height="36" Click="CancelButton_Click" Margin="0,0,10,0"/>
            <Button x:Name="OKButton" Content="确定" Style="{StaticResource PrimaryButtonStyle}"
                    Width="90" Height="36" Click="OKButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
