<Window x:Class="SunloginManager.ConnectionHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="连接历史" Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="连接历史" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="FilterComboBox" Width="150" Height="35" SelectionChanged="FilterComboBox_SelectionChanged">
                <ComboBoxItem Content="全部记录" Tag="0" IsSelected="True"/>
                <ComboBoxItem Content="最近7天" Tag="7"/>
                <ComboBoxItem Content="最近30天" Tag="30"/>
                <ComboBoxItem Content="最近90天" Tag="90"/>
            </ComboBox>
            <TextBlock x:Name="CountText" Text="共 0 条记录" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#666"/>
        </StackPanel>

        <ListView Grid.Row="2" x:Name="HistoryListView" BorderThickness="1" BorderBrush="#D1D1D6" Background="White">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="时间" Width="160" DisplayMemberBinding="{Binding StartTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"/>
                    <GridViewColumn Header="名称" Width="150" DisplayMemberBinding="{Binding ConnectionName}"/>
                    <GridViewColumn Header="识别码" Width="120" DisplayMemberBinding="{Binding IdentificationCode}"/>
                    <GridViewColumn Header="时长" Width="100" DisplayMemberBinding="{Binding DurationText}"/>
                    <GridViewColumn Header="状态" Width="80" DisplayMemberBinding="{Binding StatusText}"/>
                    <GridViewColumn Header="备注" Width="200" DisplayMemberBinding="{Binding ErrorMessage}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="关闭" Width="100" Height="35" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
