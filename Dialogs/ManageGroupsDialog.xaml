<Window x:Class="SunloginManager.ManageGroupsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理分组" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7"
        ResizeMode="CanResize">
    
    <Window.Resources>
        <!-- 苹果风格按钮样式 -->
        <Style x:Key="AppleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0051D5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004BB5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 表格行样式 -->
        <Style x:Key="TableRowStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F8FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 操作按钮样式 -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#007AFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F8FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 删除按钮样式 -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="#FF3B30"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE5E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" 
                Background="White" 
                Height="70"
                VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" ShadowDepth="2" BlurRadius="8"/>
            </Border.Effect>
            <Grid Margin="30,0">
                <TextBlock Text="分组管理" 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           VerticalAlignment="Center" 
                           Foreground="#1D1D1F"/>
                <Button Content="+ 添加分组" 
                        Click="AddGroupButton_Click"
                        HorizontalAlignment="Right"
                        Style="{StaticResource AppleButtonStyle}"
                        Width="120"
                        Height="35"/>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <Border Margin="20,90,20,20">
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.1" ShadowDepth="0" BlurRadius="15"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 表头 -->
                    <Border Grid.Row="0" 
                            Background="#F9F9F9" 
                            BorderBrush="#E5E5EA" 
                            BorderThickness="0,0,0,1"
                            CornerRadius="12,12,0,0"
                            Padding="20,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="颜色" FontWeight="SemiBold" Foreground="#8E8E93" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="分组名称" FontWeight="SemiBold" Foreground="#8E8E93" FontSize="13"/>
                            <TextBlock Grid.Column="2" Text="描述" FontWeight="SemiBold" Foreground="#8E8E93" FontSize="13"/>
                            <TextBlock Grid.Column="3" Text="操作" FontWeight="SemiBold" Foreground="#8E8E93" FontSize="13" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 分组列表 -->
                    <ListView x:Name="GroupsListView" 
                              Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="10,5"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ItemContainerStyle="{StaticResource TableRowStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 颜色指示器 -->
                                    <Ellipse Grid.Column="0" 
                                             Width="20" 
                                             Height="20"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Color, Converter={StaticResource ColorConverter}}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!-- 分组名称 -->
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Name}" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               Foreground="#1D1D1F"/>

                                    <!-- 描述 -->
                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding Description}" 
                                               FontSize="13" 
                                               Foreground="#8E8E93"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="3" 
                                                Orientation="Horizontal" 
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Content="编辑" 
                                                Click="EditGroupButton_Click"
                                                Tag="{Binding}"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Margin="0,0,5,0"/>
                                        
                                        <Button Content="删除" 
                                                Click="DeleteGroupButton_Click"
                                                Tag="{Binding}"
                                                Style="{StaticResource DeleteButtonStyle}"
                                                Visibility="{Binding IsDefault, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
